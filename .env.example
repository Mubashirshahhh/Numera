```text
# ==========================================
# Numera Environment Configuration
# Copy this file to ".env" and fill in your values.
# ==========================================

# OpenRouter API Key (Recommended)
OPENROUTER_API_KEY=

# Anthropic API Key (Optional fallback)
ANTHROPIC_API_KEY=

# OpenAI API Key (Optional)
OPENAI_API_KEY=

# Default AI model
DEFAULT_MODEL=openai/gpt-5

# Rendering
DOCKER_TIMEOUT=300

# Logging
LOG_LEVEL=INFO

# Database
DATABASE_PATH=production_state.db
```
